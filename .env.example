# MACS / ERP AI Copilot environment configuration
# Copy to `.env` and fill in your real values.

# ===== LLM Provider Keys =====
# Anthropic Claude (recommended primary for ERP copilot)
ANTHROPIC_API_KEY=

# OpenAI / MiniMax (fallback / secondary)
OPENAI_API_KEY=
MINIMAX_API_KEY=

# Other Chinese providers (optional)
QWEN_API_KEY=
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=
HUNYUAN_API_KEY=
TAVILY_API_KEY=

# Default model selection
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_FALLBACK_MODEL=MiniMax-M2.7

# ===== ERP AI Copilot / PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=erp_copilot
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_pass

# Seed scale: small=300, medium=1000, large=5000 rows per fact table
ERP_SEED_SCALE=small

# Web UI port (on host)
ERP_WEB_PORT=8001

# ===== MACS General =====
MACS_LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
